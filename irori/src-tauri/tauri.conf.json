{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Irori",
  "version": "0.1.0",
  "identifier": "jp.pettal.irori",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "DeveloperTool",
    "icon": ["icons/icon.png"]
  },
  "app": {
    "windows": [
      {
        "title": "Irori",
        "width": 1380,
        "height": 920,
        "resizable": true
      }
    ]
  }
}
