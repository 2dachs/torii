{
  "name": "irori",
  "private": true,
  "version": "0.1.0",
  "description": "Irori desktop AI chat MVP",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "tauri": "tauri",
    "tauri:dev": "PATH=\"$PWD/bin:$PATH\" tauri dev",
    "tauri:build": "PATH=\"$PWD/bin:$PATH\" tauri build",
    "app:open": "open src-tauri/target/release/bundle/macos/Irori.app",
    "app:build-open": "npm run tauri:build && npm run app:open"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.3.3",
    "vite": "^6.0.0"
  }
}
